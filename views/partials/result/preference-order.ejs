<div class="vn-card">
  <% if (!recommendedPreferenceOrder.length) { %>
    <p class="mb-0 text-center" style="color: var(--vn-ink-muted);">
      Not enough data yet to recommend a preference order.
    </p>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th style="width: 48px;">#</th>
            <th>College</th>
            <th>Why it's here</th>
            <th>Round 1 Chance</th>
          </tr>
        </thead>
        <tbody>
          <% recommendedPreferenceOrder.forEach(function (item) { %>
            <tr>
              <td><%= item.rank %></td>
              <td><%= item.collegeName %></td>
              <td>
                <% if (item.basis === 'dream_college') { %>
                  <span class="vn-badge vn-badge-success">Dream College</span>
                <% } else { %>
                  <span class="small" style="color: var(--vn-ink-muted);">Best available chance</span>
                <% } %>
              </td>
              <td>
                <% if (item.round1Chance) { %>
                  <% const meta = CHANCE_BUCKET_META[item.round1Chance]; %>
                  <span class="vn-badge <%= meta.badgeClass %>"><%= meta.label %></span>
                <% } else { %>
                  <span class="small" style="color: var(--vn-ink-muted);">&mdash;</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
