<section class="vn-section vn-hero">
  <div class="container">
    <div class="row align-items-center gy-5">
      <div class="col-12 col-lg-6">
        <p class="vn-eyebrow mb-3">MCA CET &amp; MBA CET &middot; CAP Admissions &middot; Maharashtra</p>
        <h1 class="vn-hero-title mb-3">
          Know your CAP colleges before you fill the form.
        </h1>
        <p class="fs-5 mb-4" style="color: var(--vn-ink-muted); max-width: 46ch;">
          Enter your percentile once. See every college you're likely to get,
          sorted by chance, based on official CAP cutoff data — not guesswork
          from WhatsApp groups.
        </p>
        <div class="d-flex flex-wrap gap-3">
          <a href="<%= url('/predict') %>" class="btn btn-vn-primary btn-lg">Start Prediction</a>
          <a href="#how-it-works" class="btn btn-vn-outline btn-lg">See how it works</a>
        </div>
        <p class="small mt-3 mb-0" style="color: var(--vn-ink-muted);">
          Takes about 2 minutes. No account, no password.
        </p>
      </div>

      <div class="col-12 col-lg-6">
        <div class="vn-card">
          <p class="small fw-semibold mb-3" style="color: var(--vn-ink-muted); text-transform: uppercase; letter-spacing: 0.04em;">
            Your chance, at a glance
          </p>
          <svg viewBox="0 0 560 190" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="vnSpectrumTitle" style="width:100%; height:auto;">
            <title id="vnSpectrumTitle">Example chance spectrum from Low to Very High</title>

            <!-- Four chance segments -->
            <rect x="0"   y="30" width="128" height="40" rx="10" style="fill: var(--vn-danger-bg);" />
            <rect x="144" y="30" width="128" height="40" rx="10" style="fill: var(--vn-warning-bg);" />
            <rect x="288" y="30" width="128" height="40" rx="10" style="fill: var(--vn-blue-100);" />
            <rect x="432" y="30" width="128" height="40" rx="10" style="fill: var(--vn-success-bg);" />

            <!-- Example marker pointing at "High" -->
            <polygon points="352,8 340,24 364,24" style="fill: var(--vn-blue-700);" />
            <text x="352" y="4" text-anchor="middle" font-size="11" font-family="Inter, sans-serif" font-weight="600" style="fill: var(--vn-blue-700);">Your dream college</text>

            <!-- Segment labels -->
            <text x="64"  y="55" text-anchor="middle" font-size="13" font-family="Inter, sans-serif" font-weight="600" style="fill: var(--vn-danger);">Low</text>
            <text x="208" y="55" text-anchor="middle" font-size="13" font-family="Inter, sans-serif" font-weight="600" style="fill: var(--vn-warning);">Moderate</text>
            <text x="352" y="55" text-anchor="middle" font-size="13" font-family="Inter, sans-serif" font-weight="600" style="fill: var(--vn-blue-700);">High</text>
            <text x="496" y="55" text-anchor="middle" font-size="13" font-family="Inter, sans-serif" font-weight="600" style="fill: var(--vn-success);">Very High</text>

            <!-- Caption -->
            <text x="0" y="105" font-size="13" font-family="Inter, sans-serif" style="fill: var(--vn-ink-muted);">
              Every college in your result is placed in one of these four
            </text>
            <text x="0" y="126" font-size="13" font-family="Inter, sans-serif" style="fill: var(--vn-ink-muted);">
              bands, based on how your percentile compares to previous
            </text>
            <text x="0" y="147" font-size="13" font-family="Inter, sans-serif" style="fill: var(--vn-ink-muted);">
              years' CAP round-wise, category-wise cutoffs.
            </text>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
